{
  "name": "xua-delivery",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:api & npm run dev:web",
    "dev:api": "npm run dev -w @xua/api",
    "dev:web": "npm run dev -w @xua/web",
    "build:api": "npx prisma generate",
    "build:web": "npm run build -w @xua/web",
    "start:api": "npm run start -w @xua/api",
    "start:web": "npm run start -w @xua/web",
    "lint": "npm run lint -w @xua/web",
    "typecheck:api": "npm run typecheck -w @xua/api",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "prisma generate",
    "shared:check": "tsc -p packages/shared/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@xua/shared": "*",
    "prisma": "^7.5.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tsx": "^4.19.4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
