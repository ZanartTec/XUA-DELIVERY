      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/driver/deliveries/(?<nxtPid>[^/]+?)/non\\-collection(?:/)?$"
    },
    {
      "page": "/driver/deliveries/[id]/otp",
